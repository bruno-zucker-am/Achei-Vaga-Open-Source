{
  "expo": {
    "name": "Achei Vaga Build 2",
    "slug": "achei-vaga",
    "scheme": "acheivaga",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "bundleIdentifier": "com.acheivaga.brazucasoftware"
    },
    "android": {
      "package": "com.acheivagabuild2",
      "googleServicesFile": "./google-services.json",
      "permissions": ["NOTIFICATIONS", "VIBRATE"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "extra": {
      "eas": {
        "projectId": "4b2edc89-9256-4cd4-9e95-d91604590037"
      }
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.png",
          "color": "#4CAF50"
        }
      ]
    ]
  }
}
